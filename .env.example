# Copie este arquivo para .env e preencha com suas credenciais do Supabase
# O arquivo .env NUNCA deve ser commitado (já está no .gitignore)

# Banco de dados (Supabase)
# Encontre em: Supabase → Settings → Database → Connection string → URI
DB_HOST=aws-0-sa-east-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.SEU_PROJECT_REF
DB_PASSWORD=SUA_SENHA_AQUI

# JWT (pode ser qualquer string longa e aleatória)
JWT_SECRET=SUA_CHAVE_SECRETA_LONGA_AQUI

# Porta local do servidor (opcional, padrão é 8080)
# PORT=8080
