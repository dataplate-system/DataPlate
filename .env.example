# Copie para .env e ajuste:  copy .env.example .env
# O Spring lê este arquivo direto (spring.config.import) e o dev-start.ps1 também.

# ───────────────────────────────────────────────────────────────────
# OPÇÃO A — Postgres LOCAL (recomendado: isolado da produção)
# Requer Postgres instalado e um banco vazio chamado data_plate.
# O Flyway cria o schema (V1..V7) no primeiro start.
# ───────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=data_plate
DB_USER=postgres
DB_PASSWORD=1234

# ───────────────────────────────────────────────────────────────────
# OPÇÃO B — apontar para o Fly Postgres via proxy (usa dados REAIS de produção!)
# Em outro terminal:  fly proxy 15432:5432 -a dataplate-db
# Pegue a senha:      fly ssh console -a dataplate -C "printenv SPRING_DATASOURCE_PASSWORD"
# Aí comente a Opção A acima e use:
#
# DB_HOST=localhost
# DB_PORT=15432
# DB_NAME=dataplate
# DB_USER=postgres
# DB_PASSWORD=<senha do SPRING_DATASOURCE_PASSWORD>
# spring.flyway.enabled=false        # NÃO deixe o Flyway tocar no schema de produção
# ───────────────────────────────────────────────────────────────────

# JWT (qualquer string longa para dev)
JWT_SECRET=troque-isto-por-uma-string-bem-longa-de-dev-123456789

# Imagens: o upload é direto pro Cloudinary pelo frontend (cloud dufufat0a,
# preset fotospadrao) — não precisa de variável de ambiente.
